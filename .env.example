# ============================================
# API Keys
# ============================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (for embeddings - text-embedding-3-small is cost-effective)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Vector Database Configs
# ============================================

# ChromaDB (local by default, no config needed)
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Pinecone (if using)
# PINECONE_API_KEY=your_pinecone_key
# PINECONE_ENVIRONMENT=us-west1-gcp

# Qdrant (if using cloud)
# QDRANT_URL=https://your-instance.qdrant.io
# QDRANT_API_KEY=your_qdrant_key

# ============================================
# Search APIs (optional)
# ============================================

# Tavily (AI-optimized search)
# TAVILY_API_KEY=your_tavily_key

# Brave Search (alternative)
# BRAVE_API_KEY=your_brave_key

# ============================================
# Observability & Monitoring
# ============================================

# LangSmith (for debugging & tracing)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=ai-engineering-arsenal

# ============================================
# Application Settings
# ============================================

# Model Selection
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# Development
DEBUG=true
LOG_LEVEL=INFO
